# =============================================================================
# Copy to .env.production and fill all required values before:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
# =============================================================================

# --- PostgreSQL (internal hostname: postgres) ---
POSTGRES_USER=appleberry
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=appleberry

# If the password contains @ # : / ? & etc., URL-encode it for DATABASE_URL safety
# (Compose builds DATABASE_URL from these vars automatically).

# --- API (internal hostnames: postgres, redis) ---
JWT_SECRET=change-me-long-random-min-32-chars
JWT_REFRESH_SECRET=

# Browser origins allowed by CORS (comma-separated, no spaces). Must match how
# users open the app (scheme + host + port if non-default).
# Example single origin:
CORS_ORIGIN=https://app.example.com

# JWT lifetimes (seconds)
JWT_ACCESS_SEC=900
JWT_REFRESH_SEC=604800

# Trust X-Forwarded-* from nginx (required behind reverse proxy)
TRUST_PROXY=1

# Webhook signing secret for inbound provider callbacks (set if you use webhooks)
INBOUND_WEBHOOK_SECRET=

# --- Next.js build-time (browser calls this URL; use public hostname + /api) ---
# Must NOT be http://localhost:3001 in production — use the same origin users see.
NEXT_PUBLIC_API_URL=https://app.example.com/api

# --- Nginx host port mapping (avoid conflicts with other stacks on the same host) ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# If 80/443 are already taken, e.g. NGINX_HTTP_PORT=8080 then browse http://host:8080

# =============================================================================
# Optional — pass through to API if you add them to docker-compose environment:
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# OPENAI_API_KEY=
# =============================================================================
