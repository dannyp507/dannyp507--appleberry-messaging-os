# =============================================================================
# API-only test / staging deploy (see docker-compose.api-test.yml)
#   cp .env.api-test.example .env.api-test
#   docker compose -f docker-compose.api-test.yml --env-file .env.api-test up -d --build
# =============================================================================

POSTGRES_USER=appleberry
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=appleberry

JWT_SECRET=change-me-long-random-min-32-chars
JWT_REFRESH_SECRET=

# Exact browser origins allowed (comma-separated). If you only use curl/Postman,
# set this to the same base URL you open in a browser when testing, e.g.:
#   http://203.0.113.10:3001
#   https://api-staging.example.com
CORS_ORIGIN=http://127.0.0.1:3001

# Host port published for the API (default 3001)
API_HTTP_PORT=3001

# 0 = direct access to container port; 1 = behind another reverse proxy
TRUST_PROXY=0

JWT_ACCESS_SEC=900
JWT_REFRESH_SEC=604800

INBOUND_WEBHOOK_SECRET=

WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
OPENAI_API_KEY=
