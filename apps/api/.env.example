DATABASE_URL=postgresql://appleberry:appleberry@localhost:5433/appleberry?schema=public
JWT_SECRET=change-me-use-long-random-string
JWT_REFRESH_SECRET=optional-separate-secret-for-refresh
REDIS_HOST=localhost
REDIS_PORT=6380
PORT=3001
# Comma-separated origins for the Next.js app (browser requests)
CORS_ORIGIN=http://localhost:3000
# Set to 1 when behind Nginx or a load balancer (secure cookies, client IP)
TRUST_PROXY=0
JWT_ACCESS_SEC=900
JWT_REFRESH_SEC=604800
WHATSAPP_RATE_LIMIT_PER_MIN=40
CAMPAIGN_JITTER_MIN_MS=0
CAMPAIGN_JITTER_MAX_MS=0
INBOUND_WEBHOOK_SECRET=set-a-long-random-secret-for-webhook-posts

# WhatsApp Cloud API (when using providerType CLOUD on an account)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_GRAPH_VERSION=v21.0

# OpenAI (AI replies when no keyword / autoresponder matches)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
